# PropPublish — Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env a git (está en .gitignore).

# ─── MercadoLibre / Portal Inmobiliario ────────────────────────────────────
# Crea tu app en: https://developers.mercadolibre.cl/
# Redirect URI a configurar en el panel ML: propublish://callback
ML_APP_ID=TU_APP_ID_AQUI
ML_APP_SECRET=TU_APP_SECRET_AQUI

# ─── Google Maps ────────────────────────────────────────────────────────────
# Habilita en Google Cloud Console:
#   - Maps SDK for Android
#   - Maps SDK for iOS
#   - Geocoding API
# https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=TU_GOOGLE_MAPS_API_KEY_AQUI

# ─── EAS (Expo Application Services) ───────────────────────────────────────
# Configura como secrets en EAS:
#   npx eas secret:create --name GOOGLE_MAPS_API_KEY --value "TU_KEY"
#   npx eas secret:create --name ML_APP_ID --value "TU_APP_ID"
#   npx eas secret:create --name ML_APP_SECRET --value "TU_SECRET"
